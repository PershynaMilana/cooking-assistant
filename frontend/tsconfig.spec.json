{
  // ts-jest runtime config; same as ./tsconfig.test.json except for the CommonJS
  // emit options ts-jest needs (allowImportingTsExtensions must be off because it emits)
  "extends": "./tsconfig.test-base.json",
  "compilerOptions": {
    "module": "CommonJS",
    "moduleResolution": "Node",
    "esModuleInterop": true,
    "allowImportingTsExtensions": false,
    "noEmit": false
  }
}
