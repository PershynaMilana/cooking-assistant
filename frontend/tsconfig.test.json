{
  // editor + `tsc -b` type-check view of the tests; @swc/jest transforms tests at
  // runtime (no type-check), so no separate CommonJS tsconfig is needed anymore
  "extends": "./tsconfig.app.json",
  "compilerOptions": {
    "types": ["jest", "@testing-library/jest-dom"],
    "noUnusedLocals": false,
    "noUnusedParameters": false
  },
  "include": ["src"],
  "exclude": []
}
