{
    "extends": ["stylelint-config-standard-scss", "stylelint-config-tailwindcss"],
    "rules": {
        "at-rule-no-unknown": null,
        "scss/at-rule-no-unknown": [
            true,
            {
                "ignoreAtRules": ["tailwind", "apply", "layer", "variants", "screen", "responsive"]
            }
        ],
        "keyframes-name-pattern": "^([a-z][a-zA-Z0-9]*)(-[a-z0-9]+)*$",
        "selector-no-vendor-prefix": [true, { "ignoreSelectors": ["/-webkit-/", "/-moz-/"] }],
        "property-no-vendor-prefix": [
            true,
            { "ignoreProperties": ["-webkit-font-smoothing", "-moz-osx-font-smoothing"] }
        ]
    }
}
