# Copy to backend/.env and fill in real values

# Secret used to sign/verify JWT auth tokens — set a random string of at least 32 characters
JWT_SECRET_KEY=

# Database connection (read by src/config/env.ts; reused by db.ts and the migrate/seed scripts)
DB_USER=postgres
DB_PASSWORD=
DB_HOST=localhost
DB_PORT=5432
DB_NAME=cooking_helper

# Database TLS. DB_SSL defaults to on in production, off otherwise; set DB_SSL=true/false to override.
# Set DB_SSL_REJECT_UNAUTHORIZED=false for managed Postgres presenting a private/self-signed CA.
DB_SSL=
DB_SSL_REJECT_UNAUTHORIZED=

# Server
NODE_ENV=development
PORT=3000
LOG_LEVEL=info

# Number of trusted reverse-proxy hops for req.ip / rate limiting (defaults: 1 in production, 0 otherwise)
TRUST_PROXY_HOPS=
# Global rate limit: max requests per window per client (default 300) and the window in ms (default 60000)
RATE_LIMIT_MAX=
RATE_LIMIT_WINDOW_MS=

# Allowed CORS origin (the frontend URL); change for non-local deploys
CORS_ORIGIN=http://localhost:8080

# Auth session cookie. Leave COOKIE_DOMAIN empty in dev (host-only cookie);
# in production set the shared parent domain, e.g. .example.com, so app.* and api.*
# share the cookie. Secure is enabled automatically when NODE_ENV=production.
COOKIE_DOMAIN=
