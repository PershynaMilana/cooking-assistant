# Copy to backend/.env and fill in real values

# Secret used to sign/verify JWT auth tokens — set a random string of at least 32 characters
JWT_SECRET_KEY=

# Database connection (read by src/config/env.ts; reused by db.ts and the migrate/seed scripts)
DB_USER=postgres
DB_PASSWORD=
DB_HOST=localhost
DB_PORT=5432
DB_NAME=cooking_helper

# Server
NODE_ENV=development
PORT=3000
LOG_LEVEL=info

# Allowed CORS origin (the frontend URL); change for non-local deploys
CORS_ORIGIN=http://localhost:8080

# Auth session cookie. Leave COOKIE_DOMAIN empty in dev (host-only cookie);
# in production set the shared parent domain, e.g. .example.com, so app.* and api.*
# share the cookie. Secure is enabled automatically when NODE_ENV=production.
COOKIE_DOMAIN=
