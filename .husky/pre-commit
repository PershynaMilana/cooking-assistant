# escape hatch: SKIP_CHECKS=1 git commit ... skips all local pre-commit checks.
# read the env var, NOT .git/COMMIT_EDITMSG - at pre-commit time that file still
# holds the PREVIOUS commit's message, which caused false skips.
if [ "$SKIP_CHECKS" = "1" ]; then
  echo "SKIP_CHECKS=1 set - skipping pre-commit checks"
  exit 0
fi

npx lint-staged
npm --prefix backend run typecheck
npm --prefix backend run lint
npm --prefix backend run lint:sonarjs
npm --prefix backend run test:coverage
npm --prefix frontend run typecheck
npm --prefix frontend run lint
npm --prefix frontend run lint:sonarjs
npm --prefix frontend run stylelint
npm --prefix frontend run test
