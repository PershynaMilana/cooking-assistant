# escape hatch: [skip-checks] in commit message skips pre-commit checks
if grep -q '\[skip-checks\]' "$(git rev-parse --git-dir)/COMMIT_EDITMSG" 2>/dev/null; then
  echo "[skip-checks] in commit message - skipping pre-commit checks"
  exit 0
fi

npx lint-staged
npm --prefix backend run typecheck
npm --prefix backend run lint
npm --prefix backend run lint:sonarjs
npm --prefix backend run test:coverage
npm --prefix frontend run typecheck
npm --prefix frontend run lint
npm --prefix frontend run lint:sonarjs
npm --prefix frontend run stylelint
npm --prefix frontend run test
